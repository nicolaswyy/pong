import pygame

import sys

import random

from groq import Groq
 
# --- CONFIGURAÇÃO IA ---

try:

    client = Groq(api_key="SUA_CHAVE_GROQ_AQUI")

except:

    client = None
 
# --- CONFIGURAÇÕES DO JOGO ---

WIDTH, HEIGHT = 800, 600

WHITE = (255, 255, 255)

BLACK = (0, 0, 0)

GREEN_NEON = (57, 255, 20)

FPS = 60
 
pygame.init()

screen = pygame.display.set_mode((WIDTH, HEIGHT))

pygame.display.set_caption("PONG AI - 1980s EDITION")

clock = pygame.time.Clock()

font_pixel = pygame.font.SysFont("Courier", 30, bold=True)

font_small = pygame.font.SysFont("Courier", 20, bold=True)
 
# --- ESTADOS DO JOGO ---

# 0: Nome, 1: Dificuldade, 2: Jogando

game_state = 0
 
# --- ENTIDADES E FÍSICA ---

ball = pygame.Rect(WIDTH//2 - 10, HEIGHT//2 - 10, 20, 20)

player = pygame.Rect(10, HEIGHT//2 - 50, 15, 100)

opponent = pygame.Rect(WIDTH - 25, HEIGHT//2 - 50, 15, 100)
 
ball_speed_x = 0

ball_speed_y = 0

player_speed = 0

opponent_ai_speed = 0  # Definido pela dificuldade
 
player_score = 0

opponent_score = 0

player_name = ""

ia_comment = "BEM-VINDO AO ARENA!"
 
def set_difficulty(level):

    global ball_speed_x, ball_speed_y, opponent_ai_speed

    if level == "FACIL":

        ball_speed_x, ball_speed_y = 5, 5

        opponent_ai_speed = 4

    elif level == "NORMAL":

        ball_speed_x, ball_speed_y = 7, 7

        opponent_ai_speed = 6

    elif level == "DIFICIL":

        ball_speed_x, ball_speed_y = 10, 10

        opponent_ai_speed = 9
 
def get_ia_comment(winner):

    if not client: return f"PONTO PARA {winner}!"

    try:

        response = client.chat.completions.create(

            model="llama3-8b-8192",

            messages=[{"role": "user", "content": f"O jogador {winner} pontuou no Pong. Diga algo curto de vilão de arcade 80s."}]

        )

        return response.choices[0].message.content.upper()

    except:

        return "PROCESSANDO PONTO..."
 
# --- LOOP PRINCIPAL ---

while True:

    for event in pygame.event.get():

        if event.type == pygame.QUIT:

            pygame.quit()

            sys.exit()

        # LÓGICA DE TECLADO POR ESTADO

        if game_state == 0: # Entrada de Nome

            if event.type == pygame.KEYDOWN:

                if event.key == pygame.K_RETURN and player_name != "":

                    game_state = 1

                elif event.key == pygame.K_BACKSPACE:

                    player_name = player_name[:-1]

                else:

                    if len(player_name) < 10: player_name += event.unicode
 
        elif game_state == 1: # Seleção de Dificuldade

            if event.type == pygame.KEYDOWN:

                if event.key == pygame.K_1: 

                    set_difficulty("FACIL"); game_state = 2

                if event.key == pygame.K_2: 

                    set_difficulty("NORMAL"); game_state = 2

                if event.key == pygame.K_3: 

                    set_difficulty("DIFICIL"); game_state = 2
 
        elif game_state == 2: # Jogando

            if event.type == pygame.KEYDOWN:

                if event.key == pygame.K_UP: player_speed = -8

                if event.key == pygame.K_DOWN: player_speed = 8

            if event.type == pygame.KEYUP:

                if event.key in (pygame.K_UP, pygame.K_DOWN): player_speed = 0
 
    screen.fill(BLACK)
 
    if game_state == 0:

        # TELA DE NOME

        txt = font_pixel.render("DIGITE SEU NOME:", True, GREEN_NEON)

        name_txt = font_pixel.render(f"> {player_name}_", True, WHITE)

        screen.blit(txt, (250, 250))

        screen.blit(name_txt, (320, 300))
 
    elif game_state == 1:

        # TELA DE DIFICULDADE

        txt = font_pixel.render("SELECIONE O NÍVEL:", True, GREEN_NEON)

        d1 = font_pixel.render("1 - FACIL", True, WHITE)

        d2 = font_pixel.render("2 - NORMAL", True, WHITE)

        d3 = font_pixel.render("3 - DIFICIL", True, WHITE)

        screen.blit(txt, (250, 200))

        screen.blit(d1, (300, 280)); screen.blit(d2, (300, 330)); screen.blit(d3, (300, 380))
 
    elif game_state == 2:

        # LÓGICA DE MOVIMENTO

        ball.x += ball_speed_x

        ball.y += ball_speed_y

        player.y += player_speed
 
        # IA DO OPONENTE (Segue a bola com base na velocidade da dificuldade)

        if opponent.centery < ball.y: opponent.y += opponent_ai_speed

        else: opponent.y -= opponent_ai_speed
 
        # COLISÕES PAREDES

        if ball.top <= 0 or ball.bottom >= HEIGHT:

            ball_speed_y *= -1
 
        # COLISÕES RAQUETES

        if ball.colliderect(player) or ball.colliderect(opponent):

            ball_speed_x *= -1.05 # Aumenta um pouco a velocidade a cada rebatida
 
        # PONTUAÇÃO

        if ball.left <= 0:

            opponent_score += 1

            ia_comment = get_ia_comment("CPU")

            ball.center = (WIDTH//2, HEIGHT//2)

            ball_speed_x = abs(ball_speed_x) # Manda para o player

        if ball.right >= WIDTH:

            player_score += 1

            ia_comment = get_ia_comment(player_name)

            ball.center = (WIDTH//2, HEIGHT//2)

            ball_speed_x = -abs(ball_speed_x) # Manda para a CPU
 
        # LIMITES

        player.clamp_ip(screen.get_rect())

        opponent.clamp_ip(screen.get_rect())
 
        # DESENHOS

        pygame.draw.rect(screen, WHITE, player)

        pygame.draw.rect(screen, WHITE, opponent)

        pygame.draw.ellipse(screen, GREEN_NEON, ball)

        for i in range(0, HEIGHT, 40): # Linha tracejada central

            pygame.draw.rect(screen, WHITE, (WIDTH//2 - 2, i, 4, 20))
 
        # INTERFACE PLACAR E IA

        p_text = font_pixel.render(f"{player_name}: {player_score}", True, WHITE)

        o_text = font_pixel.render(f"CPU: {opponent_score}", True, WHITE)

        comm_text = font_small.render(ia_comment[:70], True, GREEN_NEON)

        screen.blit(p_text, (50, 20))

        screen.blit(o_text, (WIDTH - 250, 20))

        screen.blit(comm_text, (20, HEIGHT - 40))
 
    pygame.display.flip()

    clock.tick(FPS)
 
